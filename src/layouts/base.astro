---
import '../styles/styles.css';
const {data} = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
        <meta name="robots" content="noai, noimageai">
        <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">

        <meta property="og:type" content="website">
        <meta property="og:title" content={data.title}>
        <meta property="og:description" content={data.description ?? data.title}>
        <meta name="description" content={data.description ?? data.title}>
        <meta property="og:image" content={data.image}>
        <meta name="theme-color" content={data.cardcolor}>
        <meta property="twitter:card" content="summary">

        <link rel="sitemap" href=`${Astro.site.href}sitemap-index.xml`/>

		<title>{data.title}</title>
	</head>
	<body>
        <content>
            <h1 class="center">{data.title}</h1>
            <slot />
        </content>
        
        <footer>
            The webmaster of this site is not a professional in whatever you're viewing a list of and does not guarantee accuracy or completeness.
            Sources to all images are linked in the label underneath each image. Source of the list is linked in the list's header.
            <div class="links">
                <a href=`${Astro.site.href}`>List of Lists with Images</a>
                <a href=`${Astro.site.href}about`>About</a>
            </div>
        </footer>
	</body>
</html>